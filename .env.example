# Copy this file to .env and fill in real values.
# .env is gitignored — never commit it.

# ── Runtime environment ───────────────────────────────────────────────────────

# Runtime environment. Set to "production" in deployed environments.
# Internal services log a warning if INTERNAL_API_KEY is not set when APP_ENV=production.
APP_ENV=development

# Comma-separated list of trusted reverse-proxy IPs whose X-Forwarded-For header
# is honoured for rate limiting. Leave empty in local dev.
# Example (Render internal IP): TRUSTED_PROXIES=10.0.0.1
TRUSTED_PROXIES=

# ── Required secrets ──────────────────────────────────────────────────────────

# JWT signing secret. Must be at least 32 characters.
# Generate one: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=

# Internal service-to-service API key.
# The gateway sends this header to NLP, Music, and Bot services which reject
# requests without it — prevents direct bypass of the gateway in production.
# Generate one: python -c "import secrets; print(secrets.token_hex(24))"
INTERNAL_API_KEY=

# PostgreSQL password for the deskbuddy user.
# Generate one: python -c "import secrets; print(secrets.token_urlsafe(24))"
POSTGRES_PASSWORD=

# ── Optional API keys (features degrade gracefully without them) ──────────────

# Anthropic Claude — primary mood analysis
ANTHROPIC_API_KEY=

# HuggingFace — fallback mood analysis
HUGGINGFACE_API_KEY=

# Spotify — music recommendations
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Cloudinary — photo uploads from the Photo Booth (check-in) page.
# Without these, photos are stored as base64 in localStorage (5 MB limit).
# Create a free account at cloudinary.com → Settings → API Keys.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
